# Copy to .env and fill in. Read secrets from env vars only (never hardcode).

# Which provider the agent calls: gemini | anthropic | openai
EVIDENCE_PROVIDER=gemini

# Provide the key for the provider you chose:
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Model id for the chosen provider.
#   gemini:    gemini-2.5-flash / gemini-2.5-pro  (confirm with scripts/list_models.py)
#   anthropic: claude-sonnet-4-6 / claude-opus-4-8
#   openai:    gpt-4o
EVIDENCE_MODEL=gemini-2.5-flash

# Gemini "extended thinking" budget: -1 dynamic, 0 off, or a token integer.
EVIDENCE_THINKING_BUDGET=-1
